APP_NAME="Error Translator API"
ENVIRONMENT="local"
DEBUG=true

# AI client configuration (Gemini)
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_API_KEY=your_gemini_api_key_here
AI_REQUEST_TIMEOUT_SECONDS=15
AI_MAX_RETRIES=2

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://error-translator.vercel.app

# Database
DATABASE_URL=postgresql+asyncpg://DB_USER:DB_PASSWORD@DB_HOST:5432/DB_NAME
MIGRATION_DATABASE_URL=postgresql+psycopg://DB_USER:DB_PASSWORD@localhost:5433/DB_NAME
POSTGRES_DB=YOUR_DB_NAME
POSTGRES_USER=YOUR_DB_USER
POSTGRES_PASSWORD=YOUR_DB_PASSWORD

# JWT
JWT_SECRET_KEY=secret-dev-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60